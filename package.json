{
  "name": "kalachain-certification-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Blockchain-enabled certification platform: soulbound ERC-721 certificates on Polygon with a Google-Sheets-driven mint pipeline",
  "scripts": {
    "dev": "ts-node backend/src/server.ts",
    "worker": "ts-node backend/src/workers/main.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:contracts": "hardhat test",
    "node:local": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^4.19.0",
    "google-auth-library": "^9.14.0",
    "google-spreadsheet": "^4.1.4",
    "nodemailer": "^6.9.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "^6.0.2",
    "hardhat": "^2.22.10",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
