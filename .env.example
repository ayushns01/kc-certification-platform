# ---- Network ----
# local = Hardhat node | amoy = Polygon Amoy testnet | polygon = mainnet (post-hire only)
NETWORK=local
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
DEPLOYER_PRIVATE_KEY=
CONTRACT_ADDRESS=
POLYGONSCAN_API_KEY=
# Optional gas cap (gwei). Amoy RPCs often suggest 200+ gwei tips while the
# validator minimum is ~25-30 — set 30 to keep faucet POL going further.
AMOY_GAS_PRICE_GWEI=30

# ---- Data backend ----
# json = zero-setup mock store (default for reviewers) | sheets = Google Sheets
DATA_BACKEND=json
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json
SHEET_POLL_INTERVAL_MS=15000

# ---- Email ----
# manual = assessment mode (mint leaves email PENDING; admin triggers dispatch)
# auto   = production mode per JD (dispatch immediately after mint)
EMAIL_MODE=manual
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Kalachain Certificates <certificates@kalachain.example>"

# ---- App ----
PORT=3000
BASE_URL=http://localhost:3000
ADMIN_API_KEY=change-me
